# SeaShield AI Agent Configuration

# ===== LLM Provider Selection =====
# Options: "ollama" (local, recommended for dev) | "openai" | "anthropic"
LLM_PROVIDER=ollama

# ===== Ollama Configuration (Local Setup) =====
# Install Ollama: https://ollama.ai
# Pull models: ollama pull llama2 (or mistral, neural-chat, etc.)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama2:latest

# ===== OpenAI Configuration (Cloud) =====
# Get API key: https://platform.openai.com/api-keys
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-xxxxxxxxxxxxxxx
# LLM_MODEL=gpt-3.5-turbo

# ===== Alert Agent Settings =====
# Enable/disable AI-based alert generation
AI_ALERT_ENABLED=true
# Fallback to template-based alerts if LLM unavailable
AI_ALERT_FALLBACK=true
# Max time (ms) to wait for LLM response
AI_ALERT_TIMEOUT=5000

# ===== Database =====
MONGODB_URI=mongodb://localhost:27017/seashield
DB_NAME=seashield

# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== WebSocket =====
SOCKET_URL=http://localhost:5000

# ===== Frontend API =====
API_URL=http://localhost:5000/api
